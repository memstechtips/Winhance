<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Winhance.UI.Features.Common.Controls.NavButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winhance.UI.Features.Common.Controls"
    xmlns:fluentIcons="using:FluentIcons.WinUI"
    IsTabStop="True"
    UseSystemFocusVisuals="True"
    AutomationProperties.Name="{x:Bind Text, Mode=OneWay}">

    <Grid x:Name="RootGrid"
          Width="{x:Bind ActualButtonWidth, Mode=OneWay}"
          Height="{x:Bind ActualButtonHeight, Mode=OneWay}"
          PointerEntered="RootGrid_PointerEntered"
          PointerExited="RootGrid_PointerExited"
          PointerPressed="RootGrid_PointerPressed"
          PointerReleased="RootGrid_PointerReleased">

        <!-- Main Button Background -->
        <Border x:Name="BackgroundBorder"
                Background="Transparent"
                CornerRadius="10"/>

        <!-- Content Stack.
             Spacing 2 (not 4) so that when Windows' "Make text bigger" scale
             bumps the 2-line label height past its default ~24dp, the icon +
             gap + text stack still fits inside the fixed 60dp button without
             clipping the icon's top edge (issue #668 iter3). -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="2"
                    Opacity="{x:Bind ContentOpacity, Mode=OneWay}">
            <!-- Colored Fluent System Icon (IconVariant=Color). The Icon name is set
                 in code-behind from IconSymbol because Icon is an enum, not a string. -->
            <fluentIcons:FluentIcon x:Name="ButtonFluentIcon"
                                    IconVariant="Color"
                                    FontSize="{x:Bind IconSize, Mode=OneWay}"
                                    HorizontalAlignment="Center"
                                    Margin="{x:Bind IconMargin, Mode=OneWay}"
                                    Visibility="{x:Bind FluentIconVisibility, Mode=OneWay}"/>

            <!-- Text (Hidden when compact).
                 Wrap to 2 lines so the default-scale rendering keeps the
                 natural "Software & Apps" / "Advanced Tools" / etc. wrap
                 behaviour; TextTrimming kicks in only when the wrapped text
                 still exceeds 2 lines at higher Windows text-scale settings
                 ("Software\n& App…"). Combined with the parent StackPanel's
                 reduced Spacing=2, this fits inside the fixed 60dp button
                 even at typical 125-150% text scale.
                 AutomationProperties.Name on the parent UserControl binds the
                 full text for screen readers, so trimming loses no info for
                 accessibility (issue #668 iter3). -->
            <TextBlock x:Name="ButtonText"
                       Text="{x:Bind Text, Mode=OneWay}"
                       FontSize="10"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxLines="2"
                       TextAlignment="Center"
                       MaxWidth="60"
                       HorizontalAlignment="Center"
                       Visibility="{x:Bind TextVisibility, Mode=OneWay}"/>
        </StackPanel>

        <!-- Left Selection Indicator -->
        <Border x:Name="SelectionIndicator"
                Width="3"
                Height="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                CornerRadius="2"
                Margin="0,0,0,0"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                Visibility="{x:Bind IndicatorVisibility, Mode=OneWay}"/>

        <!-- InfoBadge Overlay -->
        <InfoBadge x:Name="Badge"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,2,-4,0"
                   Visibility="{x:Bind BadgeVisibility, Mode=OneWay}"
                   Value="{x:Bind BadgeValue, Mode=OneWay}"/>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Background="#80000000"
                CornerRadius="10"
                Visibility="{x:Bind LoadingVisibility, Mode=OneWay}">
            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                          Width="24"
                          Height="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        </Border>

        <!-- Locked Overlay -->
        <Grid Visibility="{x:Bind LockedVisibility, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Viewbox Width="14" Height="14">
                <PathIcon Data="{StaticResource PrivacyIconPath}"
                          Foreground="#FFA500"/>
            </Viewbox>
        </Grid>
    </Grid>
</UserControl>
