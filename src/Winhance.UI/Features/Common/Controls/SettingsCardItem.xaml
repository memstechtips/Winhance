<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Winhance.UI.Features.Common.Controls.SettingsCardItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Winhance.UI.Features.Optimize.ViewModels"
    xmlns:selectors="using:Winhance.UI.Features.Common.TemplateSelectors"
    xmlns:interfaces="using:Winhance.Core.Features.Common.Interfaces"
    xmlns:local="using:Winhance.UI.Features.Common.Controls">

    <!--
    This UserControl handles selecting and displaying the appropriate input control
    based on the Setting's InputType. It should be placed INSIDE a SettingsCard,
    not used as a standalone item in SettingsExpander.ItemTemplate.

    Every control type (except Action / CheckBox / PowerPlan) is preceded by a pair
    of Quick-Set buttons: a green "Set to Recommended" and a grey "Set to Default"
    side-by-side. Visibility is driven by per-type ShowXQuickSetButtons flags on the
    ViewModel. The icons inside the buttons carry their own Foreground brush so the
    default Button.ContentPresenter ButtonForegroundPointerOver override does not
    wipe out the green/grey on hover — only the background hover tint renders.
    -->

    <UserControl.Resources>
        <!-- ComboBoxEx needs explicit style inheritance to maintain rounded corners -->
        <Style TargetType="local:ComboBoxEx" BasedOn="{StaticResource DefaultComboBoxStyle}"/>

        <!-- Template for Toggle settings -->
        <DataTemplate x:Key="ToggleSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            Visibility="{x:Bind ShowToggleQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Style="{StaticResource QuickSetRecommendedButtonStyle}"
                        Command="{x:Bind SetToggleToRecommendedCommand}"
                        ToolTipService.ToolTip="{x:Bind ToggleRecommendedTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(ToggleRecommendedTooltip), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </Button>
                    <Button
                        Style="{StaticResource QuickSetDefaultButtonStyle}"
                        Command="{x:Bind SetToggleToDefaultCommand}"
                        ToolTipService.ToolTip="{x:Bind ToggleDefaultTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(ToggleDefaultTooltip), Mode=OneWay}">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </Button>
                </StackPanel>
                <ToggleSwitch
                    IsOn="{x:Bind IsSelected, Mode=OneWay}"
                    Toggled="{x:Bind OnToggleSwitchToggled}"
                    OnContent="{x:Bind OnText}"
                    OffContent="{x:Bind OffText}"
                    AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template for Selection settings -->
        <DataTemplate x:Key="SelectionSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            Visibility="{x:Bind ShowSelectionQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Style="{StaticResource QuickSetRecommendedButtonStyle}"
                        Command="{x:Bind SetSelectionToRecommendedCommand}"
                        ToolTipService.ToolTip="{x:Bind SelectionRecommendedTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(SelectionRecommendedTooltip), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </Button>
                    <Button
                        Style="{StaticResource QuickSetDefaultButtonStyle}"
                        Command="{x:Bind SetSelectionToDefaultCommand}"
                        ToolTipService.ToolTip="{x:Bind SelectionDefaultTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(SelectionDefaultTooltip), Mode=OneWay}">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </Button>
                </StackPanel>
                <local:ComboBoxEx
                    ItemsSource="{x:Bind ComboBoxOptions}"
                    SelectedValue="{x:Bind SelectedValue, Mode=OneWay}"
                    SelectionChanged="{x:Bind OnComboBoxSelectionChanged}"
                    DropDownClosed="{x:Bind OnComboBoxDropDownClosed}"
                    SelectedValuePath="Value"
                    DisplayMemberPath="DisplayText"
                    AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template for PowerPlan selection settings (no quick-set buttons — deferred) -->
        <DataTemplate x:Key="PowerPlanSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <local:PowerPlanComboBox
                ItemsSource="{x:Bind ComboBoxOptions}"
                SelectedValue="{x:Bind SelectedValue, Mode=OneWay}"
                Loaded="OnPowerPlanComboBoxLoaded"
                Tag="{x:Bind}"
                AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
        </DataTemplate>

        <!-- Template for NumericRange settings. Both buttons together in front. -->
        <DataTemplate x:Key="NumericSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            Visibility="{x:Bind ShowNumericQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Style="{StaticResource QuickSetRecommendedButtonStyle}"
                        Command="{x:Bind SetNumericToRecommendedCommand}"
                        ToolTipService.ToolTip="{x:Bind RecommendedValueTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(RecommendedValueTooltip), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </Button>
                    <Button
                        Style="{StaticResource QuickSetDefaultButtonStyle}"
                        Command="{x:Bind SetNumericToDefaultCommand}"
                        ToolTipService.ToolTip="{x:Bind DefaultValueTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(DefaultValueTooltip), Mode=OneWay}">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </Button>
                </StackPanel>
                <NumberBox
                    Value="{x:Bind NumericValue, Mode=OneWay}"
                    ValueChanged="{x:Bind OnNumberBoxValueChanged}"
                    Loaded="{x:Bind OnNumberBoxLoaded}"
                    Minimum="{x:Bind MinValue}"
                    Maximum="{x:Bind MaxValue}"
                    SpinButtonPlacementMode="Inline"
                    SmallChange="1"
                    LargeChange="10"
                    MinWidth="120"
                    AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template for Action settings (no quick-set buttons) -->
        <DataTemplate x:Key="ActionSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <Button
                Content="{x:Bind ActionButtonText}"
                Command="{x:Bind RunActionCommand}"
                AutomationProperties.Name="{x:Bind A11yName(ActionButtonText), Mode=OneWay}"/>
        </DataTemplate>

        <!-- Template for CheckBox settings (no quick-set buttons) -->
        <DataTemplate x:Key="CheckBoxSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <CheckBox
                IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                Click="{x:Bind OnCheckBoxClick}"
                AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
        </DataTemplate>

        <!-- Template for Dual AC/DC Selection settings (laptop with battery).
             Each AC/DC combobox has its own pair of quick-set buttons in front. -->
        <DataTemplate x:Key="DualSelectionSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind PluggedInText}" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                                    Visibility="{x:Bind ShowAcSelectionQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button
                                Style="{StaticResource QuickSetRecommendedButtonStyle}"
                                Command="{x:Bind SetAcSelectionToRecommendedCommand}"
                                ToolTipService.ToolTip="{x:Bind AcSelectionRecommendedTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yAcName(AcSelectionRecommendedTooltip), Mode=OneWay}">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                          Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                            </Button>
                            <Button
                                Style="{StaticResource QuickSetDefaultButtonStyle}"
                                Command="{x:Bind SetAcSelectionToDefaultCommand}"
                                ToolTipService.ToolTip="{x:Bind AcSelectionDefaultTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yAcName(AcSelectionDefaultTooltip), Mode=OneWay}">
                                <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                          Foreground="{ThemeResource BadgeDefaultForeground}"/>
                            </Button>
                        </StackPanel>
                        <!-- Pinned to 120 px in both directions. After the popup opens
                             and closes, the ComboBox remeasures against the widest item
                             in the dropdown and a lone Width="120" doesn't always survive
                             that pass; MinWidth + MaxWidth + HorizontalAlignment=Left
                             together hold the closed-state size no matter how wide the
                             items are. With both AC + DC shown, growing the comboboxes
                             squeezes the left column and clips the badges. -->
                        <local:ComboBoxEx
                            ItemsSource="{x:Bind ComboBoxOptions}"
                            SelectedIndex="{x:Bind AcValue, Mode=OneWay}"
                            DropDownClosed="{x:Bind OnACComboBoxDropDownClosed}"
                            DisplayMemberPath="DisplayText"
                            Width="120" MinWidth="120" MaxWidth="120"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="{x:Bind AcInputAutomationName, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind OnBatteryText}" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                                    Visibility="{x:Bind ShowDcSelectionQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button
                                Style="{StaticResource QuickSetRecommendedButtonStyle}"
                                Command="{x:Bind SetDcSelectionToRecommendedCommand}"
                                ToolTipService.ToolTip="{x:Bind DcSelectionRecommendedTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yDcName(DcSelectionRecommendedTooltip), Mode=OneWay}">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                          Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                            </Button>
                            <Button
                                Style="{StaticResource QuickSetDefaultButtonStyle}"
                                Command="{x:Bind SetDcSelectionToDefaultCommand}"
                                ToolTipService.ToolTip="{x:Bind DcSelectionDefaultTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yDcName(DcSelectionDefaultTooltip), Mode=OneWay}">
                                <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                          Foreground="{ThemeResource BadgeDefaultForeground}"/>
                            </Button>
                        </StackPanel>
                        <!-- Same pin as the AC ComboBox above — see comment there. -->
                        <local:ComboBoxEx
                            ItemsSource="{x:Bind ComboBoxOptions}"
                            SelectedIndex="{x:Bind DcValue, Mode=OneWay}"
                            DropDownClosed="{x:Bind OnDCComboBoxDropDownClosed}"
                            DisplayMemberPath="DisplayText"
                            Width="120" MinWidth="120" MaxWidth="120"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="{x:Bind DcInputAutomationName, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Template for Single AC Selection settings (desktop without battery). -->
        <DataTemplate x:Key="SingleACSelectionSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            Visibility="{x:Bind ShowAcSelectionQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Style="{StaticResource QuickSetRecommendedButtonStyle}"
                        Command="{x:Bind SetAcSelectionToRecommendedCommand}"
                        ToolTipService.ToolTip="{x:Bind AcSelectionRecommendedTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(AcSelectionRecommendedTooltip), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </Button>
                    <Button
                        Style="{StaticResource QuickSetDefaultButtonStyle}"
                        Command="{x:Bind SetAcSelectionToDefaultCommand}"
                        ToolTipService.ToolTip="{x:Bind AcSelectionDefaultTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(AcSelectionDefaultTooltip), Mode=OneWay}">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </Button>
                </StackPanel>
                <local:ComboBoxEx
                    ItemsSource="{x:Bind ComboBoxOptions}"
                    SelectedIndex="{x:Bind AcValue, Mode=OneWay}"
                    DropDownClosed="{x:Bind OnACComboBoxDropDownClosed}"
                    DisplayMemberPath="DisplayText"
                    AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template for Dual AC/DC Numeric settings (laptop with battery).
             Each AC/DC spinner gets its own pair of quick-set buttons in front. -->
        <DataTemplate x:Key="DualNumericSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind PluggedInText}" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                                    Visibility="{x:Bind ShowNumericQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button
                                Style="{StaticResource QuickSetRecommendedButtonStyle}"
                                Command="{x:Bind SetAcNumericToRecommendedCommand}"
                                ToolTipService.ToolTip="{x:Bind RecommendedAcValueTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yAcName(RecommendedAcValueTooltip), Mode=OneWay}">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                          Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                            </Button>
                            <Button
                                Style="{StaticResource QuickSetDefaultButtonStyle}"
                                Command="{x:Bind SetAcNumericToDefaultCommand}"
                                ToolTipService.ToolTip="{x:Bind DefaultAcValueTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yAcName(DefaultAcValueTooltip), Mode=OneWay}">
                                <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                          Foreground="{ThemeResource BadgeDefaultForeground}"/>
                            </Button>
                        </StackPanel>
                        <NumberBox
                            Value="{x:Bind AcNumericValue, Mode=OneWay}"
                            ValueChanged="{x:Bind OnACNumberBoxValueChanged}"
                            Loaded="{x:Bind OnNumberBoxLoaded}"
                            Minimum="{x:Bind MinValue}"
                            Maximum="{x:Bind MaxValue}"
                            SpinButtonPlacementMode="Inline"
                            SmallChange="1"
                            LargeChange="10"
                            MinWidth="120"
                            AutomationProperties.Name="{x:Bind AcInputAutomationName, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind OnBatteryText}" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                                    Visibility="{x:Bind ShowNumericQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button
                                Style="{StaticResource QuickSetRecommendedButtonStyle}"
                                Command="{x:Bind SetDcNumericToRecommendedCommand}"
                                ToolTipService.ToolTip="{x:Bind RecommendedDcValueTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yDcName(RecommendedDcValueTooltip), Mode=OneWay}">
                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                          Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                            </Button>
                            <Button
                                Style="{StaticResource QuickSetDefaultButtonStyle}"
                                Command="{x:Bind SetDcNumericToDefaultCommand}"
                                ToolTipService.ToolTip="{x:Bind DefaultDcValueTooltip, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind A11yDcName(DefaultDcValueTooltip), Mode=OneWay}">
                                <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                          Foreground="{ThemeResource BadgeDefaultForeground}"/>
                            </Button>
                        </StackPanel>
                        <NumberBox
                            Value="{x:Bind DcNumericValue, Mode=OneWay}"
                            ValueChanged="{x:Bind OnDCNumberBoxValueChanged}"
                            Loaded="{x:Bind OnNumberBoxLoaded}"
                            Minimum="{x:Bind MinValue}"
                            Maximum="{x:Bind MaxValue}"
                            SpinButtonPlacementMode="Inline"
                            SmallChange="1"
                            LargeChange="10"
                            MinWidth="120"
                            AutomationProperties.Name="{x:Bind DcInputAutomationName, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Template for Single AC Numeric settings (desktop without battery). -->
        <DataTemplate x:Key="SingleACNumericSettingTemplate" x:DataType="viewModels:SettingItemViewModel">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center"
                            Visibility="{x:Bind ShowNumericQuickSetButtons, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button
                        Style="{StaticResource QuickSetRecommendedButtonStyle}"
                        Command="{x:Bind SetAcNumericToRecommendedCommand}"
                        ToolTipService.ToolTip="{x:Bind RecommendedAcValueTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(RecommendedAcValueTooltip), Mode=OneWay}">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE735;" FontSize="14"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </Button>
                    <Button
                        Style="{StaticResource QuickSetDefaultButtonStyle}"
                        Command="{x:Bind SetAcNumericToDefaultCommand}"
                        ToolTipService.ToolTip="{x:Bind DefaultAcValueTooltip, Mode=OneWay}"
                        AutomationProperties.Name="{x:Bind A11yName(DefaultAcValueTooltip), Mode=OneWay}">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}" Height="12" Width="12"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </Button>
                </StackPanel>
                <NumberBox
                    Value="{x:Bind AcNumericValue, Mode=OneWay}"
                    ValueChanged="{x:Bind OnACNumberBoxValueChanged}"
                    Loaded="{x:Bind OnNumberBoxLoaded}"
                    Minimum="{x:Bind MinValue}"
                    Maximum="{x:Bind MaxValue}"
                    SpinButtonPlacementMode="Inline"
                    SmallChange="1"
                    LargeChange="10"
                    MinWidth="120"
                    AutomationProperties.Name="{x:Bind Name, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template Selector -->
        <selectors:SettingTemplateSelector
            x:Key="SettingTemplateSelector"
            ToggleTemplate="{StaticResource ToggleSettingTemplate}"
            SelectionTemplate="{StaticResource SelectionSettingTemplate}"
            PowerPlanTemplate="{StaticResource PowerPlanSettingTemplate}"
            NumericTemplate="{StaticResource NumericSettingTemplate}"
            ActionTemplate="{StaticResource ActionSettingTemplate}"
            CheckBoxTemplate="{StaticResource CheckBoxSettingTemplate}"
            DualSelectionTemplate="{StaticResource DualSelectionSettingTemplate}"
            SingleACSelectionTemplate="{StaticResource SingleACSelectionSettingTemplate}"
            DualNumericTemplate="{StaticResource DualNumericSettingTemplate}"
            SingleACNumericTemplate="{StaticResource SingleACNumericSettingTemplate}"/>
    </UserControl.Resources>

    <!-- Just the content control that selects the appropriate input control -->
    <ContentControl
        Content="{x:Bind Setting, Mode=OneWay}"
        ContentTemplateSelector="{StaticResource SettingTemplateSelector}"
        IsTabStop="False"
        HorizontalContentAlignment="Stretch"/>
</UserControl>
