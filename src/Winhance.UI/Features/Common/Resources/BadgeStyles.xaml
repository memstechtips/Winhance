<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Winhance.UI.Features.Common.Converters"
    xmlns:fluentIcons="using:FluentIcons.WinUI">

    <!--
    BadgeStyles.xaml
    Centralized visual definition for the SettingsCard InfoBadge pill.
    Includes:
      - Pill Border styles per state (Recommended / Default / Custom)
      - Foreground brushes matching each pill style
      - Shared text style
      - The BadgeIconTemplateSelector resource with its three inline icon templates
    -->

    <!-- ==================== Pill Border Base ==================== -->
    <!--
    Height is pinned so CornerRadius can match half of it and produce a true
    capsule shape. WinUI 3 Border.CornerRadius does not always clamp large
    values (e.g. 999) to half the rendered height — especially with a 1px
    BorderThickness — so fixing both values explicitly is the reliable way
    to guarantee a pill look.
    -->
    <Style x:Key="BadgePillBase" TargetType="Border">
        <Setter Property="Height" Value="22"/>
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="Padding" Value="8,0,10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ==================== State-Specific Pill Styles ==================== -->
    <Style x:Key="BadgeRecommendedStyle" TargetType="Border" BasedOn="{StaticResource BadgePillBase}">
        <Setter Property="Background" Value="#224EC94E"/>
        <Setter Property="BorderBrush" Value="#404EC94E"/>
    </Style>

    <Style x:Key="BadgeDefaultStyle" TargetType="Border" BasedOn="{StaticResource BadgePillBase}">
        <Setter Property="Background" Value="#12FFFFFF"/>
        <Setter Property="BorderBrush" Value="#24FFFFFF"/>
    </Style>

    <Style x:Key="BadgeCustomStyle" TargetType="Border" BasedOn="{StaticResource BadgePillBase}">
        <Setter Property="Background" Value="#22F0A030"/>
        <Setter Property="BorderBrush" Value="#40F0A030"/>
    </Style>

    <Style x:Key="BadgePreferenceStyle" TargetType="Border" BasedOn="{StaticResource BadgePillBase}">
        <Setter Property="Background" Value="#2280B3FF"/>
        <Setter Property="BorderBrush" Value="#4080B3FF"/>
    </Style>

    <!-- ==================== ComboBox Option Pill Styles ==================== -->
    <!--
    Used by the Selection ComboBox ItemTemplate to highlight Recommended / Default
    options in the open dropdown list. Height auto-follows the text so the pill fits
    inside a ComboBoxItem row. SelectionBoxItemTemplate is intentionally left at the
    default TextBlock so the CLOSED dropdown shows no pill.
    -->
    <Style x:Key="ComboBoxOptionRecommendedPillStyle" TargetType="Border" BasedOn="{StaticResource BadgeRecommendedStyle}">
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="ComboBoxOptionDefaultPillStyle" TargetType="Border" BasedOn="{StaticResource BadgeDefaultStyle}">
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- ==================== Foreground Brushes ==================== -->
    <SolidColorBrush x:Key="BadgeRecommendedForeground" Color="#FF4EC94E"/>
    <SolidColorBrush x:Key="BadgeDefaultForeground" Color="#99FFFFFF"/>
    <SolidColorBrush x:Key="BadgeCustomForeground" Color="#FFF0A030"/>
    <SolidColorBrush x:Key="BadgePreferenceForeground" Color="#FF80B3FF"/>

    <!-- ==================== Text Style ==================== -->
    <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- ==================== Icon Template Selector ==================== -->
    <!-- Each template is a single icon control with the correct foreground brush.
         The 4px right margin separates the icon from the pill's text label. -->
    <converters:BadgeIconTemplateSelector x:Key="BadgeIconTemplateSelector">
        <converters:BadgeIconTemplateSelector.RecommendedTemplate>
            <DataTemplate>
                <FontIcon
                    Glyph="&#xE735;"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Margin="0,4,4,0"
                    Foreground="{StaticResource BadgeRecommendedForeground}"/>
            </DataTemplate>
        </converters:BadgeIconTemplateSelector.RecommendedTemplate>
        <converters:BadgeIconTemplateSelector.DefaultTemplate>
            <DataTemplate>
                <PathIcon
                    Data="{StaticResource BadgeDefaultIconPath}"
                    VerticalAlignment="Center"
                    Margin="0,4,4,0"
                    Height="12"
                    Width="12"
                    Foreground="{StaticResource BadgeDefaultForeground}"/>
            </DataTemplate>
        </converters:BadgeIconTemplateSelector.DefaultTemplate>
        <converters:BadgeIconTemplateSelector.CustomTemplate>
            <DataTemplate>
                <fluentIcons:SymbolIcon
                    Symbol="PersonWrench"
                    IconVariant="Regular"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Margin="0,4,4,0"
                    Foreground="{StaticResource BadgeCustomForeground}"/>
            </DataTemplate>
        </converters:BadgeIconTemplateSelector.CustomTemplate>
        <converters:BadgeIconTemplateSelector.PreferenceTemplate>
            <DataTemplate>
                <FontIcon
                    Glyph="&#xE77B;"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Margin="0,4,4,0"
                    Foreground="{StaticResource BadgePreferenceForeground}"/>
            </DataTemplate>
        </converters:BadgeIconTemplateSelector.PreferenceTemplate>
    </converters:BadgeIconTemplateSelector>

    <!-- ==================== NumericRange Quick-Set Buttons (Task B4) ==================== -->
    <!--
    Small borderless icon buttons flanking every NumericRange spinner. Visible only
    when UserPreferences.ShowInfoBadges is on. The green star matches the Recommended
    InfoBadge; the grey 2x2-grid icon matches the Default InfoBadge — keeping the
    Recommended/Default visual vocabulary consistent across InfoBadge pills,
    Quick Actions menu items, and these per-spinner buttons.
    -->
    <Style x:Key="NumericQuickSetButtonBase" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinWidth" Value="28"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="NumericQuickSetRecommendedButtonStyle" TargetType="Button"
           BasedOn="{StaticResource NumericQuickSetButtonBase}">
        <Setter Property="Foreground" Value="{StaticResource BadgeRecommendedForeground}"/>
    </Style>

    <Style x:Key="NumericQuickSetDefaultButtonStyle" TargetType="Button"
           BasedOn="{StaticResource NumericQuickSetButtonBase}">
        <Setter Property="Foreground" Value="{StaticResource BadgeDefaultForeground}"/>
    </Style>

</ResourceDictionary>
