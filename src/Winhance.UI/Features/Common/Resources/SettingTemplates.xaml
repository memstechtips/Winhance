<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    x:Class="Winhance.UI.Features.Common.Resources.SettingTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:Winhance.UI.Features.Optimize.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:commonControls="using:Winhance.UI.Features.Common.Controls"
    xmlns:models="using:Winhance.UI.Features.Common.Models"
    xmlns:converters="using:Winhance.UI.Features.Common.Converters"
    xmlns:coreModels="using:Winhance.Core.Features.Common.Models"
    xmlns:fluentIcons="using:FluentIcons.WinUI">
    <!-- Note: 'models:' is UI-layer (TechnicalDetailRow etc); 'coreModels:' is Winhance.Core (BadgePillState etc). -->
    <!-- Don't merge them. -->

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="TechnicalDetailsStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Common spacing for settings cards -->
    <x:Double x:Key="SettingsCardSpacing">4</x:Double>

    <converters:BoolToDimOpacityConverter x:Key="BoolToDimOpacityConverter"/>

    <converters:BadgePillTemplateSelector x:Key="BadgePillTemplateSelector">

        <converters:BadgePillTemplateSelector.RecommendedTemplate>
            <DataTemplate x:DataType="coreModels:BadgePillState">
                <Border
                    Style="{StaticResource BadgeRecommendedStyle}"
                    Opacity="{x:Bind IsHighlighted, Converter={StaticResource BoolToDimOpacityConverter}}"
                    ToolTipService.ToolTip="{x:Bind Tooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE735;" FontSize="12"
                                  VerticalAlignment="Center" Margin="0,1,0,0"
                                  Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                        <TextBlock Text="{x:Bind Label}"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{ThemeResource BadgeRecommendedForeground}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </converters:BadgePillTemplateSelector.RecommendedTemplate>

        <converters:BadgePillTemplateSelector.DefaultTemplate>
            <DataTemplate x:DataType="coreModels:BadgePillState">
                <Border
                    Style="{StaticResource BadgeDefaultStyle}"
                    Opacity="{x:Bind IsHighlighted, Converter={StaticResource BoolToDimOpacityConverter}}"
                    ToolTipService.ToolTip="{x:Bind Tooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="{StaticResource BadgeDefaultIconPath}"
                                  Height="12" Width="12"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource BadgeDefaultForeground}"/>
                        <TextBlock Text="{x:Bind Label}"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{ThemeResource BadgeDefaultForeground}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </converters:BadgePillTemplateSelector.DefaultTemplate>

        <converters:BadgePillTemplateSelector.CustomTemplate>
            <DataTemplate x:DataType="coreModels:BadgePillState">
                <Border
                    Style="{StaticResource BadgeCustomStyle}"
                    Opacity="{x:Bind IsHighlighted, Converter={StaticResource BoolToDimOpacityConverter}}"
                    ToolTipService.ToolTip="{x:Bind Tooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <fluentIcons:SymbolIcon Symbol="PersonWrench" IconVariant="Regular"
                                                FontSize="12" VerticalAlignment="Center"
                                                Foreground="{ThemeResource BadgeCustomForeground}"/>
                        <TextBlock Text="{x:Bind Label}"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{ThemeResource BadgeCustomForeground}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </converters:BadgePillTemplateSelector.CustomTemplate>

        <converters:BadgePillTemplateSelector.PreferenceTemplate>
            <DataTemplate x:DataType="coreModels:BadgePillState">
                <Border
                    Style="{StaticResource BadgePreferenceStyle}"
                    Opacity="{x:Bind IsHighlighted, Converter={StaticResource BoolToDimOpacityConverter}}"
                    ToolTipService.ToolTip="{x:Bind Tooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE77B;" FontSize="12"
                                  VerticalAlignment="Center" Margin="0,1,0,0"
                                  Foreground="{ThemeResource BadgePreferenceForeground}"/>
                        <TextBlock Text="{x:Bind Label}"
                                   Style="{StaticResource BadgeTextStyle}"
                                   Foreground="{ThemeResource BadgePreferenceForeground}"/>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </converters:BadgePillTemplateSelector.PreferenceTemplate>

    </converters:BadgePillTemplateSelector>

    <!-- Common layout values for settings pages -->
    <x:Double x:Key="SettingsContentMaxWidth">1000</x:Double>
    <Thickness x:Key="SettingsContentMargin">24,0,24,0</Thickness>

    <!-- SettingsCard internal spacing overrides for tighter layout -->
    <!-- Reduce padding around the icon area -->
    <Thickness x:Key="SettingsCardPadding">16,12,16,12</Thickness>
    <Thickness x:Key="SettingsCardHeaderIconMargin">0,0,16,0</Thickness>
    <x:Double x:Key="SettingsCardHeaderIconMaxSize">24</x:Double>
    <Thickness x:Key="SettingsExpanderItemPadding">16,12,16,12</Thickness>

    <!-- Style for settings section headers -->
    <Style
        x:Key="SettingsSectionHeaderTextBlockStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Style.Setters>
            <Setter Property="Margin" Value="1,30,0,6" />
        </Style.Setters>
    </Style>

    <DataTemplate x:Key="SettingItemTemplate" x:DataType="viewModels:SettingItemViewModel">
        <StackPanel Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,2">
            <!-- Main settings card with overlays -->
            <Grid>
                <controls:SettingsCard
                    IsEnabled="{x:Bind EffectiveIsEnabled, Mode=OneWay}"
                    IsTabStop="False"
                    AutomationProperties.LocalizedControlType="setting"
                    HeaderIcon="{x:Bind Converter={StaticResource IconConverter}}"
                    Padding="16,12,16,12">
                    <controls:SettingsCard.Description>
                        <commonControls:SettingDescriptionWithBadges
                            DescriptionText="{x:Bind Description}"
                            BadgeRow="{x:Bind BadgeRow, Mode=OneWay}"
                            ShowBadges="{x:Bind ShowInfoBadge, Mode=OneWay}"/>
                    </controls:SettingsCard.Description>
                    <controls:SettingsCard.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                            <Border
                                Visibility="{x:Bind ShowNewBadge, Mode=OneWay}"
                                Padding="5,1"
                                CornerRadius="3"
                                Background="#E81123"
                                VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind NewBadgeText}"
                                    Foreground="White"
                                    FontSize="10"
                                    FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </controls:SettingsCard.Header>
                    <commonControls:SettingsCardItem Setting="{x:Bind}" VerticalAlignment="Center"
                        AutomationProperties.HelpText="{x:Bind StatusBannerMessage, Mode=OneWay}"/>
                </controls:SettingsCard>

                <!-- Applying overlay with spinner -->
                <Border
                    Visibility="{x:Bind IsApplying, Mode=OneWay}"
                    Background="{ThemeResource SmokeFillColorDefaultBrush}"
                    CornerRadius="4">
                    <ProgressRing IsActive="{x:Bind IsApplying, Mode=OneWay}" Width="24" Height="24"/>
                </Border>

                <!-- Lock overlay covering entire SettingsCard -->
                <Grid Visibility="{x:Bind IsLocked, Mode=OneWay}">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition/>
                        </TransitionCollection>
                    </Grid.Transitions>
                    <!-- Semi-transparent background layer -->
                    <Border
                        Background="{ThemeResource SmokeFillColorDefaultBrush}"
                        CornerRadius="4"/>
                    <!-- Button layer with full opacity -->
                    <Button
                        Command="{x:Bind UnlockCommand}"
                        AutomationProperties.Name="{x:Bind ClickToUnlockText}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Viewbox Width="16" Height="16">
                                <Path
                                    Data="{StaticResource PrivacyIconPath}"
                                    Fill="#FFA500"
                                    Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock
                                Text="{x:Bind ClickToUnlockText}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Technical Details toggle button (seamlessly attached below SettingsCard) -->
            <Border Visibility="{x:Bind ShowTechnicalDetailsBar, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="{x:Bind TechnicalDetailsToggleCornerRadius, Mode=OneWay}"
                    Margin="0,-1,0,0">
                <Button
                    Click="{x:Bind ToggleTechnicalDetails}"
                    AutomationProperties.Name="{x:Bind TechnicalDetailsLabel}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="10,4"
                    Background="Transparent"
                    BorderThickness="0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="12" Margin="0,0,6,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind TechnicalDetailsLabel}" FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE70D;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE70E;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"/>
                    </Grid>
                </Button>
            </Border>

            <!-- Technical Details expandable content -->
            <Border Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"
                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,4,4"
                    Padding="12,6"
                    Margin="0,0,0,0">
                <ItemsRepeater ItemsSource="{x:Bind TechnicalDetailSections, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:TechnicalDetailSection">
                            <StackPanel Margin="0,4,0,0">
                                <!-- v1: section header is non-interactive label; per-section collapse is a follow-up. -->
                                <Button Style="{StaticResource TechDetail.SectionHeader}"
                                        IsHitTestVisible="False"
                                        IsTabStop="False"
                                        AutomationProperties.Name="{x:Bind Label}">
                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" FontSize="12"/>
                                </Button>
                                <ItemsRepeater ItemsSource="{x:Bind Rows}" Margin="12,4,0,8">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TechnicalDetailRow">
                                            <ContentControl IsTabStop="True"
                                                            AutomationProperties.Name="{x:Bind AccessibleSummary}"
                                                            AutomationProperties.LocalizedControlType="detail"
                                                            HorizontalContentAlignment="Stretch">
                                            <Grid>
                                                <!-- Registry row -->
                                                <Grid Visibility="{x:Bind IsRegistry}"
                                                      ColumnDefinitions="Auto,*,Auto" Padding="4,4">
                                                    <!-- Regedit open button -->
                                                    <Button Grid.Column="0" Command="{x:Bind OpenRegeditCommand}"
                                                            CommandParameter="{x:Bind RegistryPath}"
                                                            IsEnabled="{x:Bind CanOpenRegedit}"
                                                            ToolTipService.ToolTip="Open in Registry Editor"
                                                            AutomationProperties.Name="{x:Bind RegistryPath}"
                                                            Padding="4" Margin="0,0,8,0"
                                                            Background="Transparent" BorderThickness="0"
                                                            VerticalAlignment="Center">
                                                        <Grid Width="16" Height="16">
                                                            <!-- FontIcon fallback when icon extraction fails -->
                                                            <FontIcon Glyph="&#xE8A7;" FontSize="14"
                                                                      Visibility="{x:Bind RegeditIconSource, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                            <!-- Extracted regedit icon overlays FontIcon when available -->
                                                            <Image Source="{x:Bind RegeditIconSource}" Width="16" Height="16"/>
                                                        </Grid>
                                                    </Button>
                                                    <!-- Path + ValueName + Type -->
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RegistryPath}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind ValueLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind ValueName}"/>
                                                            <Run Text=" ("/><Run Text="{x:Bind ValueType}"/><Run Text=")"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <!-- Current + Recommended + Default values -->
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind CurrentValue}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedValue}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultValue}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Scheduled task row -->
                                                <Grid Visibility="{x:Bind IsScheduledTask}"
                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind TaskPath}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedState}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultState}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- PowerConfig row -->
                                                <Grid Visibility="{x:Bind IsPowerConfig}"
                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Subgroup: "/><Run Text="{x:Bind SubgroupAlias}"/><Run Text=" ("/><Run Text="{x:Bind SubgroupGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Setting: "/><Run Text="{x:Bind SettingAlias}"/><Run Text=" ("/><Run Text="{x:Bind SettingGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind CurrentAC}"/><Run Text=" DC:"/><Run Text="{x:Bind CurrentDC}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind RecommendedAC}"/><Run Text=" DC:"/><Run Text="{x:Bind RecommendedDC}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind DefaultAC}"/><Run Text=" DC:"/><Run Text="{x:Bind DefaultDC}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- PowerShell script row -->
                                                <StackPanel Visibility="{x:Bind IsPowerShellScript}" Spacing="4" Margin="0,4">
                                                    <TextBlock Text="{x:Bind ScriptLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                    <Border Style="{StaticResource TechDetail.CodeBlock.PowerShell}">
                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                            <TextBlock Text="{x:Bind ScriptBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>

                                                <!-- RegContent row -->
                                                <StackPanel Visibility="{x:Bind IsRegContent}" Spacing="4" Margin="0,4">
                                                    <TextBlock Text="{x:Bind ContentLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                    <Border Style="{StaticResource TechDetail.CodeBlock.RegContent}">
                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                            <TextBlock Text="{x:Bind ContentBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Dependency chip row -->
                                                <Border Visibility="{x:Bind IsDependency}" Style="{StaticResource TechDetail.DependencyChip}" HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{x:Bind DependencyLabel}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{x:Bind DependencyRelation}" Opacity="0.7"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>

            <!-- Status banner below the settings card (QuietInfoBar suppresses
                 InfoBarAutomationPeer's hardcoded Assertive live setting) -->
            <Border Visibility="{x:Bind HasStatusBanner, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <commonControls:QuietInfoBar
                    IsOpen="{x:Bind HasStatusBanner, Mode=OneWay}"
                    Severity="{x:Bind StatusBannerSeverity, Mode=OneWay}"
                    Message="{x:Bind StatusBannerMessage, Mode=OneWay}"
                    IsClosable="False"
                    IsTabStop="True"
                    UseSystemFocusVisuals="True"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4"/>
            </Border>

            <!-- Review mode diff banner (shown when a config diff exists for this setting) -->
            <Border Visibility="{x:Bind HasReviewDiff, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <InfoBar
                    IsOpen="{x:Bind HasReviewDiff, Mode=OneWay}"
                    Severity="Warning"
                    IsClosable="False"
                    AutomationProperties.LiveSetting="Off"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4">
                    <InfoBar.Content>
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,8,4">
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind ReviewDiffMessage, Mode=OneWay}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="1"
                                Content="Apply"
                                GroupName="{x:Bind SettingId}"
                                IsChecked="{x:Bind IsReviewApproved, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="2"
                                Content="Don't apply"
                                GroupName="{x:Bind SettingId}"
                                IsChecked="{x:Bind IsReviewRejected, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </InfoBar.Content>
                </InfoBar>
            </Border>

            <!-- Review mode action banner (shown for action settings like wallpaper alongside a diff) -->
            <Border Visibility="{x:Bind HasReviewAction, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <InfoBar
                    IsOpen="{x:Bind HasReviewAction, Mode=OneWay}"
                    Severity="Warning"
                    IsClosable="False"
                    AutomationProperties.LiveSetting="Off"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4">
                    <InfoBar.Content>
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,8,4">
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind ReviewActionMessage, Mode=OneWay}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="1"
                                Content="Apply"
                                GroupName="{x:Bind ReviewActionGroupName}"
                                IsChecked="{x:Bind IsReviewActionApproved, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="2"
                                Content="Don't apply"
                                GroupName="{x:Bind ReviewActionGroupName}"
                                IsChecked="{x:Bind IsReviewActionRejected, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </InfoBar.Content>
                </InfoBar>
            </Border>
        </StackPanel>
    </DataTemplate>

    <!-- Template for parent settings that have children - renders as SettingsExpander -->
    <DataTemplate x:Key="SettingExpanderItemTemplate" x:DataType="viewModels:SettingItemViewModel">
        <StackPanel Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,2">
            <!-- Parent setting card with expand/collapse chevron -->
            <Grid>
                <controls:SettingsCard
                    IsEnabled="{x:Bind EffectiveIsEnabled, Mode=OneWay}"
                    IsClickEnabled="True"
                    Click="{x:Bind ToggleExpander}"
                    IsTabStop="False"
                    AutomationProperties.LocalizedControlType="setting"
                    HeaderIcon="{x:Bind Converter={StaticResource IconConverter}}"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="4,4,0,0"
                    Padding="{StaticResource SettingsCardPadding}">
                    <!-- Hide the built-in > action icon that appears with IsClickEnabled -->
                    <controls:SettingsCard.Resources>
                        <x:Double x:Key="SettingsCardActionIconMaxSize">0</x:Double>
                        <Thickness x:Key="SettingsCardActionIconMargin">0</Thickness>
                    </controls:SettingsCard.Resources>

                    <controls:SettingsCard.Description>
                        <commonControls:SettingDescriptionWithBadges
                            DescriptionText="{x:Bind Description}"
                            BadgeRow="{x:Bind BadgeRow, Mode=OneWay}"
                            ShowBadges="{x:Bind ShowInfoBadge, Mode=OneWay}"/>
                    </controls:SettingsCard.Description>

                    <controls:SettingsCard.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                            <Border
                                Visibility="{x:Bind ShowNewBadge, Mode=OneWay}"
                                Padding="5,1"
                                CornerRadius="3"
                                Background="#E81123"
                                VerticalAlignment="Center">
                                <TextBlock
                                    Text="{x:Bind NewBadgeText}"
                                    Foreground="White"
                                    FontSize="10"
                                    FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </controls:SettingsCard.Header>

                    <!-- Parent's input control + expand/collapse chevron -->
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <commonControls:SettingsCardItem Setting="{x:Bind}" VerticalAlignment="Center"
                            AutomationProperties.HelpText="{x:Bind StatusBannerMessage, Mode=OneWay}"/>
                        <Grid Width="20" Height="20">
                            <FontIcon Glyph="&#xE70E;" FontSize="16"
                                      Visibility="{x:Bind IsExpanderExpanded, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="16"
                                      Visibility="{x:Bind IsExpanderExpanded, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                      Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>

                </controls:SettingsCard>

                <!-- Applying overlay with spinner -->
                <Border
                    Visibility="{x:Bind IsApplying, Mode=OneWay}"
                    Background="{ThemeResource SmokeFillColorDefaultBrush}"
                    CornerRadius="4">
                    <ProgressRing IsActive="{x:Bind IsApplying, Mode=OneWay}" Width="24" Height="24"/>
                </Border>

                <!-- Lock overlay covering entire SettingsExpander -->
                <Grid Visibility="{x:Bind IsLocked, Mode=OneWay}">
                    <Grid.Transitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition/>
                        </TransitionCollection>
                    </Grid.Transitions>
                    <!-- Semi-transparent background layer -->
                    <Border
                        Background="{ThemeResource SmokeFillColorDefaultBrush}"
                        CornerRadius="4"/>
                    <!-- Button layer with full opacity -->
                    <Button
                        Command="{x:Bind UnlockCommand}"
                        AutomationProperties.Name="{x:Bind ClickToUnlockText}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Viewbox Width="16" Height="16">
                                <Path
                                    Data="{StaticResource PrivacyIconPath}"
                                    Fill="#FFA500"
                                    Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock
                                Text="{x:Bind ClickToUnlockText}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <!-- Technical Details toggle button -->
            <Border Visibility="{x:Bind ShowTechnicalDetailsBar, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="{x:Bind TechnicalDetailsToggleCornerRadius, Mode=OneWay}"
                    Margin="0,-1,0,0">
                <Button
                    Click="{x:Bind ToggleTechnicalDetails}"
                    AutomationProperties.Name="{x:Bind TechnicalDetailsLabel}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="10,4"
                    Background="Transparent"
                    BorderThickness="0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="12" Margin="0,0,6,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind TechnicalDetailsLabel}" FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE70D;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <FontIcon Grid.Column="2" Glyph="&#xE70E;" FontSize="9"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"/>
                    </Grid>
                </Button>
            </Border>

            <!-- Technical Details expandable content -->
            <Border Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"
                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,4,4"
                    Padding="12,6"
                    Margin="0,0,0,0">
                <ItemsRepeater ItemsSource="{x:Bind TechnicalDetailSections, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:TechnicalDetailSection">
                            <StackPanel Margin="0,4,0,0">
                                <!-- v1: section header is non-interactive label; per-section collapse is a follow-up. -->
                                <Button Style="{StaticResource TechDetail.SectionHeader}"
                                        IsHitTestVisible="False"
                                        IsTabStop="False"
                                        AutomationProperties.Name="{x:Bind Label}">
                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" FontSize="12"/>
                                </Button>
                                <ItemsRepeater ItemsSource="{x:Bind Rows}" Margin="12,4,0,8">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="6"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TechnicalDetailRow">
                                            <ContentControl IsTabStop="True"
                                                            AutomationProperties.Name="{x:Bind AccessibleSummary}"
                                                            AutomationProperties.LocalizedControlType="detail"
                                                            HorizontalContentAlignment="Stretch">
                                            <Grid>
                                                <!-- Registry row -->
                                                <Grid Visibility="{x:Bind IsRegistry}"
                                                      ColumnDefinitions="Auto,*,Auto" Padding="4,4">
                                                    <Button Grid.Column="0" Command="{x:Bind OpenRegeditCommand}"
                                                            CommandParameter="{x:Bind RegistryPath}"
                                                            IsEnabled="{x:Bind CanOpenRegedit}"
                                                            ToolTipService.ToolTip="Open in Registry Editor"
                                                            AutomationProperties.Name="{x:Bind RegistryPath}"
                                                            Padding="4" Margin="0,0,8,0"
                                                            Background="Transparent" BorderThickness="0"
                                                            VerticalAlignment="Center">
                                                        <Grid Width="16" Height="16">
                                                            <FontIcon Glyph="&#xE8A7;" FontSize="14"
                                                                      Visibility="{x:Bind RegeditIconSource, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                            <Image Source="{x:Bind RegeditIconSource}" Width="16" Height="16"/>
                                                        </Grid>
                                                    </Button>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RegistryPath}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind ValueLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind ValueName}"/>
                                                            <Run Text=" ("/><Run Text="{x:Bind ValueType}"/><Run Text=")"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind CurrentValue}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedValue}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultValue}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Scheduled task row -->
                                                <Grid Visibility="{x:Bind IsScheduledTask}"
                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind TaskPath}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedState}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultState}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- PowerConfig row -->
                                                <Grid Visibility="{x:Bind IsPowerConfig}"
                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Subgroup: "/><Run Text="{x:Bind SubgroupAlias}"/><Run Text=" ("/><Run Text="{x:Bind SubgroupGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                            <Run FontWeight="SemiBold" Text="Setting: "/><Run Text="{x:Bind SettingAlias}"/><Run Text=" ("/><Run Text="{x:Bind SettingGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind CurrentAC}"/><Run Text=" DC:"/><Run Text="{x:Bind CurrentDC}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind RecommendedAC}"/><Run Text=" DC:"/><Run Text="{x:Bind RecommendedDC}"/>
                                                        </TextBlock>
                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind DefaultAC}"/><Run Text=" DC:"/><Run Text="{x:Bind DefaultDC}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- PowerShell script row -->
                                                <StackPanel Visibility="{x:Bind IsPowerShellScript}" Spacing="4" Margin="0,4">
                                                    <TextBlock Text="{x:Bind ScriptLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                    <Border Style="{StaticResource TechDetail.CodeBlock.PowerShell}">
                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                            <TextBlock Text="{x:Bind ScriptBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>

                                                <!-- RegContent row -->
                                                <StackPanel Visibility="{x:Bind IsRegContent}" Spacing="4" Margin="0,4">
                                                    <TextBlock Text="{x:Bind ContentLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                    <Border Style="{StaticResource TechDetail.CodeBlock.RegContent}">
                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                            <TextBlock Text="{x:Bind ContentBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Dependency chip row -->
                                                <Border Visibility="{x:Bind IsDependency}" Style="{StaticResource TechDetail.DependencyChip}" HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{x:Bind DependencyLabel}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{x:Bind DependencyRelation}" Opacity="0.7"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>

            <!-- Status banner -->
            <Border Visibility="{x:Bind HasStatusBanner, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <commonControls:QuietInfoBar
                    IsOpen="{x:Bind HasStatusBanner, Mode=OneWay}"
                    Severity="{x:Bind StatusBannerSeverity, Mode=OneWay}"
                    Message="{x:Bind StatusBannerMessage, Mode=OneWay}"
                    IsClosable="False"
                    IsTabStop="True"
                    UseSystemFocusVisuals="True"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4"/>
            </Border>

            <!-- Review mode diff banner -->
            <Border Visibility="{x:Bind HasReviewDiff, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <InfoBar
                    IsOpen="{x:Bind HasReviewDiff, Mode=OneWay}"
                    Severity="Warning"
                    IsClosable="False"
                    AutomationProperties.LiveSetting="Off"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4">
                    <InfoBar.Content>
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,8,4">
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind ReviewDiffMessage, Mode=OneWay}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="1"
                                Content="Apply"
                                GroupName="{x:Bind SettingId}"
                                IsChecked="{x:Bind IsReviewApproved, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="2"
                                Content="Don't apply"
                                GroupName="{x:Bind SettingId}"
                                IsChecked="{x:Bind IsReviewRejected, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </InfoBar.Content>
                </InfoBar>
            </Border>

            <!-- Review mode action banner -->
            <Border Visibility="{x:Bind HasReviewAction, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Margin="0,0,0,8">
                <InfoBar
                    IsOpen="{x:Bind HasReviewAction, Mode=OneWay}"
                    Severity="Warning"
                    IsClosable="False"
                    AutomationProperties.LiveSetting="Off"
                    Margin="0,-1,0,0"
                    CornerRadius="0,0,4,4">
                    <InfoBar.Content>
                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,4,8,4">
                            <TextBlock
                                Grid.Column="0"
                                Text="{x:Bind ReviewActionMessage, Mode=OneWay}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="1"
                                Content="Apply"
                                GroupName="{x:Bind ReviewActionGroupName}"
                                IsChecked="{x:Bind IsReviewActionApproved, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                            <RadioButton
                                Grid.Column="2"
                                Content="Don't apply"
                                GroupName="{x:Bind ReviewActionGroupName}"
                                IsChecked="{x:Bind IsReviewActionRejected, Mode=TwoWay}"
                                Margin="8,0,0,0"
                                MinWidth="0"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </InfoBar.Content>
                </InfoBar>
            </Border>

            <!-- Children rendered below the expander with full template support (tech details, banners) -->
            <ItemsRepeater ItemsSource="{x:Bind Children}"
                           Visibility="{x:Bind IsExpanderExpanded, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="0"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:SettingItemViewModel">
                        <StackPanel Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <controls:SettingsCard
                                    IsEnabled="{x:Bind EffectiveIsEnabled, Mode=OneWay}"
                                    IsTabStop="False"
                                    AutomationProperties.LocalizedControlType="setting"
                                    HeaderIcon="{x:Bind Converter={StaticResource IconConverter}}"
                                    CornerRadius="{x:Bind ChildCornerRadius, Mode=OneWay}"
                                    BorderThickness="1,0,1,1"
                                    Padding="54,12,52,12">
                                    <controls:SettingsCard.Description>
                                        <commonControls:SettingDescriptionWithBadges
                                            DescriptionText="{x:Bind Description}"
                                            BadgeRow="{x:Bind BadgeRow, Mode=OneWay}"
                                            ShowBadges="{x:Bind ShowInfoBadge, Mode=OneWay}"/>
                                    </controls:SettingsCard.Description>
                                    <controls:SettingsCard.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                            <Border
                                                Visibility="{x:Bind ShowNewBadge, Mode=OneWay}"
                                                Padding="5,1"
                                                CornerRadius="3"
                                                Background="#E81123"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    Text="{x:Bind NewBadgeText}"
                                                    Foreground="White"
                                                    FontSize="10"
                                                    FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </controls:SettingsCard.Header>
                                    <commonControls:SettingsCardItem Setting="{x:Bind}" VerticalAlignment="Center"
                                        AutomationProperties.HelpText="{x:Bind StatusBannerMessage, Mode=OneWay}"/>
                                </controls:SettingsCard>

                                <!-- Applying overlay -->
                                <Border
                                    Visibility="{x:Bind IsApplying, Mode=OneWay}"
                                    Background="{ThemeResource SmokeFillColorDefaultBrush}"
                                    CornerRadius="4">
                                    <ProgressRing IsActive="{x:Bind IsApplying, Mode=OneWay}" Width="24" Height="24"/>
                                </Border>
                            </Grid>

                            <!-- Technical Details toggle button -->
                            <Border Visibility="{x:Bind ShowTechnicalDetailsBar, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1,0,1,1"
                                    CornerRadius="{x:Bind TechnicalDetailsToggleCornerRadius, Mode=OneWay}"
                                    Margin="0,-1,0,0">
                                <Button
                                    Click="{x:Bind ToggleTechnicalDetails}"
                                    AutomationProperties.Name="{x:Bind TechnicalDetailsLabel}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Padding="10,4"
                                    Background="Transparent"
                                    BorderThickness="0">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="12" Margin="0,0,6,0"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind TechnicalDetailsLabel}" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <FontIcon Grid.Column="2" Glyph="&#xE70D;" FontSize="9"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        <FontIcon Grid.Column="2" Glyph="&#xE70E;" FontSize="9"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"/>
                                    </Grid>
                                </Button>
                            </Border>

                            <!-- Technical Details expandable content -->
                            <Border Visibility="{x:Bind IsTechnicalDetailsExpanded, Mode=OneWay}"
                                    Background="{ThemeResource InfoBarInformationalSeverityBackgroundBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1,0,1,1"
                                    CornerRadius="0,0,4,4"
                                    Padding="12,6"
                                    Margin="0,0,0,0">
                                <ItemsRepeater ItemsSource="{x:Bind TechnicalDetailSections, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Spacing="8"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TechnicalDetailSection">
                                            <StackPanel Margin="0,4,0,0">
                                                <!-- v1: section header is non-interactive label; per-section collapse is a follow-up. -->
                                                <Button Style="{StaticResource TechDetail.SectionHeader}"
                                                        IsHitTestVisible="False"
                                                        IsTabStop="False"
                                                        AutomationProperties.Name="{x:Bind Label}">
                                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" FontSize="12"/>
                                                </Button>
                                                <ItemsRepeater ItemsSource="{x:Bind Rows}" Margin="12,4,0,8">
                                                    <ItemsRepeater.Layout>
                                                        <StackLayout Spacing="6"/>
                                                    </ItemsRepeater.Layout>
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="models:TechnicalDetailRow">
                                                            <ContentControl IsTabStop="True"
                                                                            AutomationProperties.Name="{x:Bind AccessibleSummary}"
                                                                            AutomationProperties.LocalizedControlType="detail"
                                                                            HorizontalContentAlignment="Stretch">
                                                            <Grid>
                                                                <!-- Registry row -->
                                                                <Grid Visibility="{x:Bind IsRegistry}"
                                                                      ColumnDefinitions="Auto,*,Auto" Padding="4,4">
                                                                    <Button Grid.Column="0" Command="{x:Bind OpenRegeditCommand}"
                                                                            CommandParameter="{x:Bind RegistryPath}"
                                                                            IsEnabled="{x:Bind CanOpenRegedit}"
                                                                            ToolTipService.ToolTip="Open in Registry Editor"
                                                                            AutomationProperties.Name="{x:Bind RegistryPath}"
                                                                            Padding="4" Margin="0,0,8,0"
                                                                            Background="Transparent" BorderThickness="0"
                                                                            VerticalAlignment="Center">
                                                                        <Grid Width="16" Height="16">
                                                                            <FontIcon Glyph="&#xE8A7;" FontSize="14"
                                                                                      Visibility="{x:Bind RegeditIconSource, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                                            <Image Source="{x:Bind RegeditIconSource}" Width="16" Height="16"/>
                                                                        </Grid>
                                                                    </Button>
                                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RegistryPath}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind ValueLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind ValueName}"/>
                                                                            <Run Text=" ("/><Run Text="{x:Bind ValueType}"/><Run Text=")"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center"
                                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind CurrentValue}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedValue}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultValue}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <!-- Scheduled task row -->
                                                                <Grid Visibility="{x:Bind IsScheduledTask}"
                                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind PathLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind TaskPath}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind RecommendedState}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="{x:Bind DefaultState}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <!-- PowerConfig row -->
                                                                <Grid Visibility="{x:Bind IsPowerConfig}"
                                                                      ColumnDefinitions="*,Auto" Padding="4,4">
                                                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                                            <Run FontWeight="SemiBold" Text="Subgroup: "/><Run Text="{x:Bind SubgroupAlias}"/><Run Text=" ("/><Run Text="{x:Bind SubgroupGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11"
                                                                                   IsTextSelectionEnabled="True" TextWrapping="Wrap">
                                                                            <Run FontWeight="SemiBold" Text="Setting: "/><Run Text="{x:Bind SettingAlias}"/><Run Text=" ("/><Run Text="{x:Bind SettingGuid}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/><Run Text=")"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                                                                HorizontalAlignment="Right" Margin="12,0,0,0" MinWidth="175">
                                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind CurrentLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind CurrentAC}"/><Run Text=" DC:"/><Run Text="{x:Bind CurrentDC}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind RecommendedLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind RecommendedAC}"/><Run Text=" DC:"/><Run Text="{x:Bind RecommendedDC}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="Consolas" FontSize="11" IsTextSelectionEnabled="True">
                                                                            <Run FontWeight="SemiBold" Text="{x:Bind DefaultLabel}"/><Run FontWeight="SemiBold" Text=": "/><Run Text="AC:"/><Run Text="{x:Bind DefaultAC}"/><Run Text=" DC:"/><Run Text="{x:Bind DefaultDC}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <!-- PowerShell script row -->
                                                                <StackPanel Visibility="{x:Bind IsPowerShellScript}" Spacing="4" Margin="0,4">
                                                                    <TextBlock Text="{x:Bind ScriptLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                                    <Border Style="{StaticResource TechDetail.CodeBlock.PowerShell}">
                                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                                            <TextBlock Text="{x:Bind ScriptBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- RegContent row -->
                                                                <StackPanel Visibility="{x:Bind IsRegContent}" Spacing="4" Margin="0,4">
                                                                    <TextBlock Text="{x:Bind ContentLabel}" FontWeight="SemiBold" Opacity="0.8"/>
                                                                    <Border Style="{StaticResource TechDetail.CodeBlock.RegContent}">
                                                                        <ScrollViewer MaxHeight="240" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                                            <TextBlock Text="{x:Bind ContentBody}" Style="{StaticResource TechDetail.CodeText}" Padding="0,0,0,16"/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </StackPanel>

                                                                <!-- Dependency chip row -->
                                                                <Border Visibility="{x:Bind IsDependency}" Style="{StaticResource TechDetail.DependencyChip}" HorizontalAlignment="Left">
                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="{x:Bind DependencyLabel}" FontWeight="SemiBold"/>
                                                                        <TextBlock Text="{x:Bind DependencyRelation}" Opacity="0.7"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                            </ContentControl>
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Border>

                            <!-- Status banner -->
                            <Border Visibility="{x:Bind HasStatusBanner, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Margin="0,0,0,8">
                                <commonControls:QuietInfoBar
                                    IsOpen="{x:Bind HasStatusBanner, Mode=OneWay}"
                                    Severity="{x:Bind StatusBannerSeverity, Mode=OneWay}"
                                    Message="{x:Bind StatusBannerMessage, Mode=OneWay}"
                                    IsClosable="False"
                                    IsTabStop="True"
                                    UseSystemFocusVisuals="True"
                                    Margin="0,-1,0,0"
                                    CornerRadius="0,0,4,4"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </DataTemplate>

    <!-- ListViewItem container style for settings lists - removes default padding/margins -->
    <Style x:Key="SettingsListViewItemContainerStyle" TargetType="ListViewItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        HorizontalAlignment="Stretch"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Group header template for settings lists -->
    <DataTemplate x:Key="SettingsGroupHeaderTemplate">
        <TextBlock
            Text="{Binding Key}"
            Visibility="{Binding HasVisibleItems, Converter={StaticResource BooleanToVisibilityConverter}}"
            Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>
    </DataTemplate>

</ResourceDictionary>
